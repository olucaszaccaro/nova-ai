{
  "headers": [
    {
      "source": "/curso",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" },
        { "key": "Pragma", "value": "no-cache" }
      ]
    },
    {
      "source": "/members/index.html",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" },
        { "key": "Pragma", "value": "no-cache" }
      ]
    },
    {
      "source": "/assets/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    }
  ],
  "redirects": [
    {
      "source": "/",
      "has": [{ "type": "host", "value": "grupo.revolucao.school" }],
      "destination": "/grupo",
      "permanent": false
    }
  ],
  "rewrites": [
    {
      "source": "/",
      "has": [{ "type": "host", "value": "grupo.revolucao.school" }],
      "destination": "/grupo/index.html"
    },
    {
      "source": "/startai",
      "destination": "/startai/index.html"
    },
    {
      "source": "/curso",
      "destination": "/members/index.html"
    },
    {
      "source": "/grupo",
      "destination": "/grupo/index.html"
    },
    {
      "source": "/materiais",
      "destination": "/materiais/index.html"
    }
  ]
}
